    "prepack": "pnpm run build",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "yazl": "^3.3.1"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/yazl": "^3.3.1",
    "esbuild": "^0.28.0",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0",
    "vitest": "^3.2.0"
  }
}
