{
  "name": "@preapp/cli",
  "version": "0.2.3",
  "description": "Agent-first CLI for PreApp: publish AI-generated HTML decks/reports, share review links, and pull human feedback back into coding agents.",
  "license": "MIT",
  "homepage": "https://github.com/serrendypity/preapp-agent#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/serrendypity/preapp-agent.git"
  },
  "bugs": {
    "url": "https://github.com/serrendypity/preapp-agent/issues"
  },
  "keywords": [
    "ai-agent",
    "claude-code",
    "codex",
    "cli",
    "html",
    "artifact",
    "feedback",
    "presentation",
    "mcp"
  ],
  "private": false,
  "type": "module",
  "bin": {
    "preapp": "dist/preapp.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "tsx src/main.ts",
